# ── Binance API Keys ──────────────────────────────────────────────────────────
# Get these from: https://www.binance.com/en/my/settings/api-management
#
# IMPORTANT BINANCE API KEY SETTINGS:
#   ✓ Enable "Enable Spot & Margin Trading"
#   ✗ Disable "Enable Withdrawals"  ← NEVER enable this for a bot
#   ✓ Restrict to IP: 127.0.0.1    ← locks key to your machine only
#
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── Risk Management ───────────────────────────────────────────────────────────
# Bot will refuse to place orders once this daily loss (in USD) is hit.
# Resets at midnight or when server restarts.
MAX_DAILY_LOSS_USD=100
